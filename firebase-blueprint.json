{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with balances",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "balanceUSD": { "type": "number" },
        "totalWithdrawn": { "type": "number" },
        "createdAt": { "type": "number" }
      },
      "required": ["uid", "email", "name", "phone", "balanceUSD", "totalWithdrawn", "createdAt"]
    },
    "Investment": {
      "title": "Investment",
      "description": "An active or pending investment locked pool",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "packageId": { "type": "string" },
        "investAmount": { "type": "number" },
        "returnAmount": { "type": "number" },
        "durationDays": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" },
        "transactionId": { "type": "string" },
        "senderPhone": { "type": "string" },
        "senderName": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "notes": { "type": "string" },
        "approvedAt": { "type": "number" },
        "maturedAt": { "type": "number" }
      },
      "required": ["id", "userId", "packageId", "investAmount", "returnAmount", "durationDays", "timestamp", "status", "transactionId", "senderPhone", "senderName", "screenshotUrl"]
    },
    "Withdrawal": {
      "title": "Withdrawal",
      "description": "Mobile money cash out request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amountUSD": { "type": "number" },
        "phone": { "type": "string" },
        "network": { "type": "string" },
        "timestamp": { "type": "number" },
        "status": { "type": "string" },
        "completedAt": { "type": "number" }
      },
      "required": ["id", "userId", "amountUSD", "phone", "network", "timestamp", "status"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System or user event notification",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "timestamp": { "type": "number" },
        "read": { "type": "boolean" }
      },
      "required": ["id", "userId", "title", "message", "type", "timestamp", "read"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "#/entities/User",
      "description": "User profile document owned by the user"
    },
    "investments/{investmentId}": {
      "schema": "#/entities/Investment",
      "description": "Investment pool document owned by user and managed by admins"
    },
    "withdrawals/{withdrawalId}": {
      "schema": "#/entities/Withdrawal",
      "description": "Mobile money payout request"
    },
    "notifications/{notificationId}": {
      "schema": "#/entities/Notification",
      "description": "Event notification logs"
    }
  }
}
